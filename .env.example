ENV=dev

DATABASE_URL=postgresql+psycopg://exceptionops:exceptionops@db:5432/exceptionops
DB_AUTO_CREATE=false

TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=exception-resolution

OPENAI_API_KEY=
AI_PROVIDER=mock
AI_MODEL=mock-heuristic-v1
# Optional V2 task-specific routing overrides. Leave blank to stay on the V1-compatible
# global AI_PROVIDER / AI_MODEL path.
AI_TRIAGE_PROVIDER=
AI_TRIAGE_MODEL=
AI_PLANNER_PROVIDER=
AI_PLANNER_MODEL=
AI_PLANNER_ESCALATION_PROVIDER=
AI_PLANNER_ESCALATION_MODEL=
AI_FALLBACK_PROVIDER=
AI_FALLBACK_MODEL=
AI_TRIAGE_CONFIDENCE_THRESHOLD=0.8
AI_ENABLED=true
EVIDENCE_ADAPTER=mock
EXECUTION_ADAPTER=mock

# Local operator login:
#   username: admin
#   password: exceptionops-local-admin
OPERATOR_SESSION_SECRET=change-me-local-session-secret
OPERATOR_SESSION_TTL_SECONDS=28800
OPERATOR_SECURE_COOKIES=false
OPERATOR_USERS_JSON={"admin":{"password_hash":"pbkdf2_sha256$390000$b3BlcmF0b3ItZGV2c2FsdA$ufqgffCje2broOAlBkIrYGOUHEw_ghZGXqBviC7xpRU","roles":["admin"]}}
OPERATOR_USERS_FILE=

APP_HOST=127.0.0.1
APP_PORT=8000
